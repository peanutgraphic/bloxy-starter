APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# S-17 (Pass 2 M4): session cookie Secure flag.
# Production MUST be true; HTTPS-only deployments depend on this.
# Set to false ONLY for local HTTP dev. Laravel's default is null which
# resolves to false — leave that for dev, override in production.
SESSION_SECURE_COOKIE=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ───────────────────────────────────────────────────────────────────────────
# BLOXY
# ───────────────────────────────────────────────────────────────────────────

# bloxy-files: which Laravel disk to use (defined in config/filesystems.php).
BLOXY_FILES_DISK=bloxy
BLOXY_FILES_DRIVER=local
BLOXY_FILES_PREFIX=bloxy/files

# bloxy-core audit log
BLOXY_AUDIT_SIGNED_CHAIN=false
BLOXY_AUDIT_HMAC_KEY=
BLOXY_AUDIT_CAPTURE_BODY=false

# bloxy-crypto: leave MOCK off in any non-local environment.
BLOXY_CRYPTO_MOCK=false

# bloxy-passkey: relying-party identity. RP_ID must match the registrable
# domain (no scheme, no port). RP_NAME is shown in the OS auth prompt.
BLOXY_PASSKEY_RP_ID=localhost
BLOXY_PASSKEY_RP_NAME="${APP_NAME}"
BLOXY_PASSKEY_RP_ORIGINS=http://localhost

# bloxy-passkey routes auto-mount when this is non-empty (default 'passkey'
# yields /passkey/register/begin etc.). Set to an empty string to disable
# the routes entirely (e.g., during a Breeze-only phase).
BLOXY_PASSKEY_ROUTE_PREFIX=passkey

# bloxy-passkey recovery flow JWT signing key (HS256, ≥32 bytes).
# REQUIRED — leave empty and the recovery endpoints will throw at boot.
BLOXY_PASSKEY_RECOVERY_JWT_KEY=
